const llyWeeks = ['W1','W2','W3','W4','W5','W6','W7','W8','W9','W10','W11','W12'];
const llyTRx   = [1.4, 3.2, 5.8, 7.3, 11.2, 17.0, 11.7, 14.5, 16.8, 18.2, 19.5, 21.0];
