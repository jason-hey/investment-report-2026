<!-- ══════════════════════ SCRIPTS ══════════════════════ -->
<script>
// ─── TICKER ───
const tickerData = {{ ticker_data | tojson }};
const inner = document.getElementById('tickerInner');
let html = '';
const items = [...tickerData, ...tickerData];
items.forEach(d => {
  html += `<div class="ticker-item">
    <span class="ticker-symbol">${d.sym}</span>
    <span class="ticker-price">${d.price}</span>
    <span class="${d.up?'ticker-up':'ticker-dn'}">${d.chg} ${d.pct}</span>
  </div>`;
});
inner.innerHTML = html;

// ─── VIX CHART ───
const vixRaw = {{ vix_history | tojson }};

const vixLabels = vixRaw.map(d => {
  const parts = d.date.split('-');
  return `${parts[1]}/${parts[2]}`;
});
const vixValues = vixRaw.map(d => d.value);

// Color points based on value
const vixPointColors = vixValues.map(v => v > 25 ? '#ff3d71' : v < 15 ? '#00e676' : '#ffa726');
const vixLineColors = vixValues.map(v => v > 25 ? '#ff3d71' : v < 15 ? '#00e676' : '#ffa726');

const vixCtx = document.getElementById('vixChart').getContext('2d');
const vixGradient = vixCtx.createLinearGradient(0, 0, 0, 300);
vixGradient.addColorStop(0, 'rgba(255,167,38,0.25)');
vixGradient.addColorStop(1, 'rgba(255,167,38,0)');

new Chart(vixCtx, {
  type: 'line',
  data: {
    labels: vixLabels,
    datasets: [{
      label: 'VIX',
      data: vixValues,
      borderColor: '#ffa726',
      backgroundColor: vixGradient,
      borderWidth: 1.5,
      pointRadius: 0,
      pointHoverRadius: 4,
      tension: 0.3,
      fill: true,
      segment: {
        borderColor: ctx => {
          const v = vixValues[ctx.p1DataIndex];
          return v > 25 ? '#ff3d71' : v < 15 ? '#00e676' : '#ffa726';
        }
      }
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: true,
    interaction: { mode: 'index', intersect: false },
    plugins: {
      legend: { display: false },
      datalabels: { display: false },
      tooltip: {
        backgroundColor: 'rgba(4,4,13,0.92)',
        titleColor: '#c8d0ec',
        bodyColor: '#f0f2fc',
        borderColor: '#2a2a4a',
        borderWidth: 1,
      },
      annotation: undefined
    },
    scales: {
      x: {
        grid: { color: 'rgba(255,255,255,0.04)', drawTicks: false },
        ticks: { color: '#c8d0ec', maxTicksLimit: 12, font: { family: 'IBM Plex Mono', size: 10 } },
        border: { color: 'rgba(255,255,255,0.08)' }
      },
      y: {
        grid: { color: 'rgba(255,255,255,0.04)' },
        ticks: { color: '#c8d0ec', font: { family: 'IBM Plex Mono', size: 10 } },
        border: { color: 'rgba(255,255,255,0.08)' },
        min: 10, max: 38
      }
    }
  },
  plugins: [{
    afterDraw(chart) {
      const { ctx, chartArea: { left, right }, scales: { y } } = chart;
      [[20, '#ffa726', '⚠ VIX 20 警戒'], [30, '#ff3d71', '🔴 VIX 30 恐慌']].forEach(([val, color, label]) => {
        const yPos = y.getPixelForValue(val);
        ctx.save();
        ctx.setLineDash([5, 5]);
        ctx.strokeStyle = color;
        ctx.globalAlpha = 0.6;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(left, yPos);
        ctx.lineTo(right, yPos);
        ctx.stroke();
        ctx.globalAlpha = 1;
        ctx.setLineDash([]);
        ctx.fillStyle = color;
        ctx.font = '10px IBM Plex Mono';
        ctx.fillText(label, left + 4, yPos - 4);
        ctx.restore();
      });
    }
  }]
});

// ─── P/E DATA ───
const peData = {{ pe_data | tojson }};

let currentPEMarket = 'tw';
let currentPEPeriod = '1y';
let peChart = null;

function buildPEChart() {
  const mktBtns = document.querySelectorAll('[onclick^="switchPEMarket"]');
  const periodBtns = document.querySelectorAll('[onclick^="switchPEPeriod"]');

  const items = peData[currentPEMarket];
  const periodKey = currentPEPeriod === '1y' ? 'trailing_1y' : 'trailing_3y';

  // Get all unique dates
  const allDates = new Set();
  items.forEach(it => it[periodKey].forEach(d => allDates.add(d.date)));
  const labels = Array.from(allDates).sort();

  const datasets = [];
  items.forEach(item => {
    const dataMap = {};
    item[periodKey].forEach(d => dataMap[d.date] = d.pe);
    datasets.push({
      label: item.name + ' Trailing',
      data: labels.map(l => dataMap[l] ?? null),
      borderColor: item.color,
      backgroundColor: 'transparent',
      borderWidth: 2,
      pointRadius: 2,
      pointHoverRadius: 5,
      tension: 0.3,
      borderDash: [],
      spanGaps: true
    });
    if (item.current_forward_pe !== null) {
      datasets.push({
        label: item.name + ' Fwd',
        data: labels.map(() => item.current_forward_pe),
        borderColor: item.color,
        backgroundColor: 'transparent',
        borderWidth: 1.5,
        pointRadius: 0,
        tension: 0,
        borderDash: [6, 4],
        spanGaps: true
      });
    }
  });

  const ctx = document.getElementById('peChart').getContext('2d');
  if (peChart) peChart.destroy();
  peChart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: true,
          labels: { color: '#c8d0ec', font: { family: 'IBM Plex Mono', size: 10 }, boxWidth: 16, padding: 10 }
        },
        datalabels: { display: false },
        tooltip: {
          backgroundColor: 'rgba(4,4,13,0.92)',
          titleColor: '#c8d0ec', bodyColor: '#f0f2fc',
          borderColor: '#2a2a4a', borderWidth: 1,
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: { color: '#c8d0ec', maxTicksLimit: 10, font: { family: 'IBM Plex Mono', size: 10 } },
          border: { color: 'rgba(255,255,255,0.08)' }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: { color: '#c8d0ec', font: { family: 'IBM Plex Mono', size: 10 }, callback: v => v + 'x' },
          border: { color: 'rgba(255,255,255,0.08)' }
        }
      }
    }
  });

  // Toggle overlays
  document.getElementById('pe-overlay-tw').style.display = currentPEMarket === 'tw' ? 'block' : 'none';
  document.getElementById('pe-overlay-us').style.display = currentPEMarket === 'us' ? 'block' : 'none';
}

function switchPEMarket(market, btn) {
  currentPEMarket = market;
  document.querySelectorAll('[onclick^="switchPEMarket"]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  buildPEChart();
}
function switchPEPeriod(period, btn) {
  currentPEPeriod = period;
  document.querySelectorAll('[onclick^="switchPEPeriod"]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  buildPEChart();
}
buildPEChart();

// ─── OIL CHART ───
// dates/wti_values/brent_values 已在 Python 端（build_oil_context）依日期聯集對齊過，
// 兩條線缺資料的日期會是 null（Chart.js 對 null 值只是這個點不畫，不會造成後續錯位）。
const oilDates = {{ oil.dates | tojson }};
const oilWtiValues = {{ oil.wti_values | tojson }};
const oilBrentValues = {{ oil.brent_values | tojson }};
const oilLabels = oilDates.map(d => { const p = d.split('-'); return `${p[1]}/${p[2]}`; });
const oilCtx = document.getElementById('oilChart').getContext('2d');
new Chart(oilCtx, {
  type: 'line',
  data: {
    labels: oilLabels,
    datasets: [
      {
        label: 'WTI', data: oilWtiValues,
        borderColor: '#ffa726', backgroundColor: 'transparent',
        borderWidth: 1.5, pointRadius: 0, pointHoverRadius: 4, tension: 0.3, spanGaps: true,
      },
      {
        label: 'Brent', data: oilBrentValues,
        borderColor: '#00d4ff', backgroundColor: 'transparent',
        borderWidth: 1.5, pointRadius: 0, pointHoverRadius: 4, tension: 0.3, spanGaps: true,
      }
    ]
  },
  options: {
    responsive: true, maintainAspectRatio: true,
    interaction: { mode: 'index', intersect: false },
    plugins: {
      legend: { display: true, labels: { color: '#c8d0ec', font: { family: 'IBM Plex Mono', size: 10 } } },
      datalabels: { display: false },
      tooltip: {
        backgroundColor: 'rgba(4,4,13,0.92)', titleColor: '#c8d0ec', bodyColor: '#f0f2fc',
        borderColor: '#2a2a4a', borderWidth: 1,
      }
    },
    scales: {
      x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#c8d0ec', maxTicksLimit: 12, font: { family: 'IBM Plex Mono', size: 10 } }, border: { color: 'rgba(255,255,255,0.08)' } },
      y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#c8d0ec', font: { family: 'IBM Plex Mono', size: 10 } }, border: { color: 'rgba(255,255,255,0.08)' } }
    }
  }
});

// ─── LLY Foundayo Charts ───
// weekly_trx / wow_pct 來自 AI 敘述 JSON（lly_foundayo），trx 為實際週處方量（份），
// 圖表 y 軸沿用既有「千份（K）」刻度顯示習慣，故除以 1000 換算。
const llyWeeklyTrx = {{ lly_foundayo.weekly_trx | tojson }};
const llyWowPct = {{ lly_foundayo.wow_pct | tojson }};
const llyWeeks = llyWeeklyTrx.map(d => d.week);
const llyTRx   = llyWeeklyTrx.map(d => d.trx / 1000);
const llyWowWeeks = llyWowPct.map(d => d.week);
const llyWoW = llyWowPct.map(d => d.pct);

const llyColors = llyWoW.map(v => v === null ? '#c8d0ec' : v >= 0 ? '#00e676' : '#ff3d71');

const llyCCtx = document.getElementById('llyCChart').getContext('2d');
const llyGrad = llyCCtx.createLinearGradient(0,0,0,160);
llyGrad.addColorStop(0,'rgba(0,212,255,0.3)');
llyGrad.addColorStop(1,'rgba(0,212,255,0)');

new Chart(llyCCtx, {
  type:'line',
  data:{
    labels:llyWeeks,
    datasets:[{
      label:'Foundayo TRx（千份）',
      data:llyTRx,
      borderColor:'#00d4ff',
      backgroundColor:llyGrad,
      borderWidth:2,
      pointRadius:4,
      pointBackgroundColor:'#00d4ff',
      tension:0.3,
      fill:true
    }]
  },
  options:{
    responsive:true, maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      datalabels:{display:false},
      tooltip:{
        backgroundColor:'rgba(4,4,13,0.92)',
        titleColor:'#c8d0ec', bodyColor:'#f0f2fc',
        borderColor:'#2a2a4a',borderWidth:1,
        callbacks:{ label: ctx => `TRx: ${ctx.parsed.y}K 份（IQVIA估）` }
      }
    },
    scales:{
      x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#c8d0ec',font:{family:'IBM Plex Mono',size:10}},border:{color:'rgba(255,255,255,0.08)'}},
      y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#c8d0ec',font:{family:'IBM Plex Mono',size:10},callback:v=>v+'K'},min:0,border:{color:'rgba(255,255,255,0.08)'}}
    }
  }
});

const llyWowCtx = document.getElementById('llyWowChart').getContext('2d');
new Chart(llyWowCtx, {
  type:'bar',
  data:{
    labels:llyWowWeeks,
    datasets:[{
      label:'WoW %',
      data:llyWoW,
      backgroundColor:llyColors,
      borderRadius:4
    }]
  },
  options:{
    responsive:true, maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      datalabels:{
        display:true,
        color:ctx => llyWoW[ctx.dataIndex] >= 0 ? '#00e676' : '#ff3d71',
        font:{family:'IBM Plex Mono',size:9,weight:'600'},
        formatter:(v) => v === null ? '' : (v>=0?'+':'')+v+'%',
        anchor:'end', align:'end', offset:-2
      },
      tooltip:{
        backgroundColor:'rgba(4,4,13,0.92)',
        titleColor:'#c8d0ec', bodyColor:'#f0f2fc',
        borderColor:'#2a2a4a',borderWidth:1
      }
    },
    scales:{
      x:{grid:{display:false},ticks:{color:'#c8d0ec',font:{family:'IBM Plex Mono',size:10}},border:{color:'rgba(255,255,255,0.08)'}},
      y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#c8d0ec',font:{family:'IBM Plex Mono',size:9},callback:v=>v+'%'},border:{color:'rgba(255,255,255,0.08)'},min:-50,max:180}
    }
  },
  plugins:[ChartDataLabels]
});

// ─── TAB FUNCTIONS ───
function switchNews(tab, btn) {
  document.querySelectorAll('.news-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.news-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('news-'+tab).classList.add('active');
}
function switchInst(tab, btn) {
  document.querySelectorAll('.inst-tabs .tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.inst-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('inst-'+tab).classList.add('active');
}
function filterEarnings(filter, btn) {
  document.querySelectorAll('.earnings-filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const rows = document.querySelectorAll('#earningsTable tbody tr');
  rows.forEach(r => {
    if (filter === 'all') { r.style.display = ''; return; }
    r.style.display = r.dataset.market === filter ? '' : 'none';
  });
}
</script>
