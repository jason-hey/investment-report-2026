<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>每日投資情報 — {{ date_label }} {{ weekday_cn }}</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<style>
:root {
  --bg: #04040d;
  --bg2: #0a0a1a;
  --bg3: #0f0f22;
  --bg4: #141428;
  --border: #1e1e3a;
  --border2: #2a2a4a;
  --text-primary: #f0f2fc;
  --text-secondary: #c8d0ec;
  --accent-blue: #4f8ef7;
  --accent-cyan: #00d4ff;
  --accent-green: #00e676;
  --accent-red: #ff3d71;
  --accent-amber: #ffa726;
  --accent-purple: #b388ff;
  --accent-gold: #ffd600;
  --glow-blue: rgba(79,142,247,0.15);
  --glow-green: rgba(0,230,118,0.15);
  --glow-red: rgba(255,61,113,0.15);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  overflow-x: hidden;
}
/* ─── TICKER ─── */
.ticker-wrap {
  width: 100%;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  height: 36px;
  display: flex;
  align-items: center;
  position: sticky; top: 0; z-index: 100;
}
.ticker-inner {
  display: flex;
  animation: ticker 55s linear infinite;
  white-space: nowrap;
  gap: 0;
}
.ticker-item {
  display: inline-flex;
  align-items: center;
  padding: 0 24px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  border-right: 1px solid var(--border);
  gap: 8px;
}
.ticker-symbol { color: var(--text-secondary); }
.ticker-price { color: var(--text-primary); font-weight: 600; }
.ticker-up { color: var(--accent-green); }
.ticker-dn { color: var(--accent-red); }
@keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ─── LAYOUT ─── */
.container { max-width: 1400px; margin: 0 auto; padding: 0 20px; }
.section { padding: 24px 0; }

/* ─── HEADER ─── */
.header {
  background: linear-gradient(135deg, #06061a 0%, #0c0c28 50%, #08081e 100%);
  border-bottom: 1px solid var(--border);
  padding: 28px 0 20px;
}
.header-top { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.header-title { display: flex; flex-direction: column; gap: 6px; }
.header-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 4px; }
.badge {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 20px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.badge-live { background: rgba(0,230,118,0.15); color: var(--accent-green); border: 1px solid rgba(0,230,118,0.3); }
.badge-tw { background: rgba(79,142,247,0.15); color: var(--accent-blue); border: 1px solid rgba(79,142,247,0.3); }
.badge-us { background: rgba(179,136,255,0.15); color: var(--accent-purple); border: 1px solid rgba(179,136,255,0.3); }
.badge-holiday { background: rgba(255,167,38,0.15); color: var(--accent-amber); border: 1px solid rgba(255,167,38,0.3); }
.header-h1 { font-size: 28px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em; }
.header-sub { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--text-secondary); }
.header-pills { display: flex; gap: 10px; flex-wrap: wrap; }
.pill {
  display: flex; align-items: center; gap: 6px;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 13px;
  font-weight: 500;
}
.pill-icon { font-size: 16px; }
.pill-green { border-color: rgba(0,230,118,0.3); background: rgba(0,230,118,0.05); }
.pill-red { border-color: rgba(255,61,113,0.3); background: rgba(255,61,113,0.05); }
.pill-amber { border-color: rgba(255,167,38,0.3); background: rgba(255,167,38,0.05); }
.pill-blue { border-color: rgba(79,142,247,0.3); background: rgba(79,142,247,0.05); }

/* ─── HERO ─── */
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:768px){ .hero-grid { grid-template-columns: 1fr; } }
.hero-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  position: relative;
  overflow: hidden;
}
.hero-card::before {
  content:'';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  border-radius: 12px 12px 0 0;
}
.hero-card.theme-green::before { background: linear-gradient(90deg, var(--accent-green), var(--accent-cyan)); }
.hero-card.theme-amber::before { background: linear-gradient(90deg, var(--accent-amber), var(--accent-red)); }
.hero-card.theme-red::before { background: linear-gradient(90deg, var(--accent-red), var(--accent-amber)); }
.hero-label { font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:8px; }
.hero-headline { font-size:17px; font-weight:700; color:var(--text-primary); line-height:1.4; margin-bottom:10px; }
.hero-body { font-size:13px; color:var(--text-secondary); line-height:1.7; }
.hero-number { font-family:'IBM Plex Mono',monospace; font-size:28px; font-weight:700; }
.hero-number.green { color: var(--accent-green); }
.hero-number.red { color: var(--accent-red); }
.hero-number.amber { color: var(--accent-amber); }

/* ─── SECTION TITLE ─── */
.sec-title {
  font-size: 18px; font-weight: 700; color: var(--text-primary);
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.sec-title-icon { font-size:20px; }
.sec-subtitle { font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text-secondary); margin-left:auto; }

/* ─── WARNING INDICATORS ─── */
.warning-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 12px; }
@media(max-width:1100px){ .warning-grid { grid-template-columns: repeat(3,1fr); } }
@media(max-width:600px){ .warning-grid { grid-template-columns: 1fr 1fr; } }
.w-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px;
  text-align: center;
  position: relative;
}
.w-card-label { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
.w-card-val { font-family:'IBM Plex Mono',monospace; font-size:22px; font-weight:700; line-height:1.1; }
.w-card-sub { font-size:11px; color:var(--text-secondary); margin-top:4px; }
.w-card-status { font-size:10px; font-weight:600; padding:2px 8px; border-radius:20px; margin-top:6px; display:inline-block; }
.status-ok { background:rgba(0,230,118,0.12); color:var(--accent-green); }
.status-warn { background:rgba(255,167,38,0.12); color:var(--accent-amber); }
.status-danger { background:rgba(255,61,113,0.12); color:var(--accent-red); }
.green { color: var(--accent-green); }
.red { color: var(--accent-red); }
.amber { color: var(--accent-amber); }
.blue { color: var(--accent-blue); }
.purple { color: var(--accent-purple); }
.cyan { color: var(--accent-cyan); }
.gold { color: var(--accent-gold); }

/* ─── DATA VALIDATION ─── */
.val-grid { display:flex; gap:8px; flex-wrap:wrap; }
.val-item {
  display:flex; align-items:center; gap:6px;
  background:var(--bg3);
  border:1px solid var(--border);
  border-radius:6px;
  padding:4px 10px;
  font-family:'IBM Plex Mono',monospace;
  font-size:11px;
  color:var(--text-secondary);
}
.val-ok { color:var(--accent-green); }
.val-est { color:var(--accent-amber); }

/* ─── KPI ─── */
.kpi-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
@media(max-width:900px){ .kpi-grid { grid-template-columns:repeat(2,1fr); } }
.kpi-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:16px;
}
.kpi-label { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px; }
.kpi-val { font-family:'IBM Plex Mono',monospace; font-size:26px; font-weight:700; line-height:1.1; color:var(--text-primary); }
.kpi-sub { font-size:11px; color:var(--text-secondary); margin-top:4px; }
.kpi-change { font-family:'IBM Plex Mono',monospace; font-size:13px; font-weight:600; }

/* ─── AI INFRA ─── */
.infra-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
@media(max-width:900px){ .infra-grid { grid-template-columns:1fr; } }
.infra-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:12px;
  padding:18px;
  position:relative;
}
.infra-card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px; }
.infra-card-title { font-size:14px; font-weight:700; color:var(--text-primary); }
.infra-card-badge { font-family:'IBM Plex Mono',monospace; font-size:10px; padding:2px 8px; border-radius:20px; }
.infra-row { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid var(--border); }
.infra-row:last-of-type { border-bottom:none; }
.infra-company { font-size:12px; color:var(--text-secondary); font-family:'IBM Plex Mono',monospace; }
.infra-num { font-family:'IBM Plex Mono',monospace; font-size:13px; font-weight:600; color:var(--text-primary); }
.infra-yoy { font-family:'IBM Plex Mono',monospace; font-size:12px; font-weight:600; color:var(--accent-green); }
.infra-src { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); margin-top:10px; }
.bar-bg { background:var(--bg3); border-radius:4px; height:6px; margin-top:4px; }
.bar-fill { border-radius:4px; height:6px; }

/* ─── CHART ─── */
.chart-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  position: relative;
}
.chart-title { font-size:14px; font-weight:700; color:var(--text-primary); margin-bottom:4px; }
.chart-sub { font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text-secondary); margin-bottom:14px; }
canvas { max-width:100%; }

/* ─── US HEATMAP ─── */
.heatmap-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(90px, 1fr)); gap:6px; }
.heatmap-cell { border-radius:6px; padding:10px 6px; text-align:center; font-family:'IBM Plex Mono',monospace; }
.heatmap-symbol { font-size:12px; font-weight:700; color:var(--text-primary); }
.heatmap-pct { font-size:11px; margin-top:2px; }
.heat-strong-up { background:rgba(0,230,118,0.35); }
.heat-up { background:rgba(0,230,118,0.15); }
.heat-flat { background:var(--bg3); }
.heat-down { background:rgba(255,61,113,0.15); }
.heat-strong-down { background:rgba(255,61,113,0.35); }

/* ─── TABS ─── */
.tab-bar { display:flex; gap:4px; margin-bottom:14px; }
.tab-btn {
  font-family:'IBM Plex Mono',monospace;
  font-size:12px;
  padding:6px 16px;
  border-radius:6px;
  border:1px solid var(--border2);
  background:var(--bg3);
  color:var(--text-secondary);
  cursor:pointer;
  transition:all 0.2s;
}
.tab-btn.active {
  background:var(--accent-blue);
  color:#fff;
  border-color:var(--accent-blue);
}
.tab-content { display:none; }
.tab-content.active { display:block; }

/* ─── PE OVERLAY TABLE ─── */
.pe-overlay {
  position:absolute;
  top:50px; right:20px;
  background:rgba(4,4,13,0.88);
  border:1px solid var(--border2);
  border-radius:8px;
  padding:10px 14px;
  font-family:'IBM Plex Mono',monospace;
  font-size:11px;
  z-index:10;
  backdrop-filter:blur(6px);
  min-width:200px;
}
.pe-ov-row { display:flex; justify-content:space-between; gap:12px; padding:3px 0; border-bottom:1px solid rgba(255,255,255,0.05); color:var(--text-secondary); }
.pe-ov-row:last-child { border-bottom:none; }
.pe-ov-name { color:var(--text-primary); font-weight:600; }

/* ─── VIX LEGEND ─── */
.vix-legend { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:10px; }
.vix-leg-item { display:flex; align-items:center; gap:6px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--text-secondary); }
.vix-leg-dot { width:12px; height:3px; border-radius:2px; }

/* ─── FUTURES CARD ─── */
.futures-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:12px;
  padding:20px;
}
.futures-main { display:flex; align-items:flex-end; gap:16px; margin-bottom:14px; }
.futures-price { font-family:'IBM Plex Mono',monospace; font-size:42px; font-weight:700; line-height:1; }
.futures-chg { font-family:'IBM Plex Mono',monospace; font-size:18px; font-weight:600; }
.futures-meta-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
@media(max-width:700px){ .futures-meta-grid { grid-template-columns:repeat(2,1fr); } }
.futures-meta-item { background:var(--bg3); border-radius:8px; padding:10px; text-align:center; }
.futures-meta-label { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.08em; }
.futures-meta-val { font-family:'IBM Plex Mono',monospace; font-size:16px; font-weight:700; color:var(--text-primary); margin-top:2px; }

/* ─── INSTITUTION TABLE ─── */
.inst-tabs { display:flex; gap:4px; margin-bottom:12px; }
.inst-panel { display:none; }
.inst-panel.active { display:block; }
.inst-cols { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
@media(max-width:700px){ .inst-cols { grid-template-columns:1fr; } }
.inst-col { background:var(--bg3); border-radius:10px; overflow:hidden; }
.inst-col-header { padding:10px 14px; font-size:13px; font-weight:700; display:flex; align-items:center; gap:8px; }
.inst-col-header.buy { background:rgba(0,230,118,0.12); color:var(--accent-green); }
.inst-col-header.sell { background:rgba(255,61,113,0.12); color:var(--accent-red); }
.inst-table { width:100%; border-collapse:collapse; font-family:'IBM Plex Mono',monospace; font-size:11px; }
.inst-table th { padding:6px 10px; color:var(--text-secondary); font-weight:500; border-bottom:1px solid var(--border); text-align:left; }
.inst-table td { padding:6px 10px; border-bottom:1px solid rgba(30,30,58,0.4); color:var(--text-primary); }
.inst-table tr:last-child td { border-bottom:none; }
.inst-table tr:nth-child(even) td { background:rgba(255,255,255,0.02); }
.inst-amt-buy { color:var(--accent-green); font-weight:600; }
.inst-amt-sell { color:var(--accent-red); font-weight:600; }
.inst-src { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); margin-top:8px; }

/* ─── LLY FOUNDAYO ─── */
.lly-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:12px;
  padding:20px;
  position:relative;
}
.lly-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px; }
.lly-latest-box { text-align:right; }
.lly-latest-trx { font-family:'IBM Plex Mono',monospace; font-size:32px; font-weight:700; color:var(--accent-cyan); }
.lly-latest-label { font-size:11px; color:var(--text-secondary); }
.lly-latest-wow { font-family:'IBM Plex Mono',monospace; font-size:15px; font-weight:600; margin-top:4px; }
.lly-warning { background:rgba(255,167,38,0.08); border:1px solid rgba(255,167,38,0.25); border-radius:8px; padding:10px 14px; font-size:12px; color:var(--accent-amber); margin-bottom:14px; }
.lly-chart-wrap { position:relative; height:180px; margin-bottom:8px; }
.lly-wow-wrap { height:80px; }

/* ─── EARNINGS ─── */
.earnings-filter { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px; }
.earnings-filter-btn {
  font-family:'IBM Plex Mono',monospace;
  font-size:11px;
  padding:4px 12px;
  border-radius:20px;
  border:1px solid var(--border2);
  background:var(--bg3);
  color:var(--text-secondary);
  cursor:pointer;
  transition:all 0.2s;
}
.earnings-filter-btn.active { background:var(--accent-purple); color:#fff; border-color:var(--accent-purple); }
.earnings-table { width:100%; border-collapse:collapse; font-family:'IBM Plex Mono',monospace; font-size:12px; }
.earnings-table th { padding:8px 12px; color:var(--text-secondary); font-weight:500; border-bottom:1px solid var(--border); text-align:left; }
.earnings-table td { padding:8px 12px; border-bottom:1px solid rgba(30,30,58,0.4); color:var(--text-primary); }
.earnings-table tr:hover td { background:rgba(255,255,255,0.02); }

/* ─── NEWS ─── */
.news-tabs { display:flex; gap:4px; flex-wrap:wrap; margin-bottom:14px; }
.news-tab { font-family:'IBM Plex Mono',monospace; font-size:11px; padding:5px 14px; border-radius:6px; border:1px solid var(--border2); background:var(--bg3); color:var(--text-secondary); cursor:pointer; transition:all 0.2s; }
.news-tab.active { background:var(--accent-cyan); color:#0a0a1a; border-color:var(--accent-cyan); font-weight:700; }
.news-panel { display:none; }
.news-panel.active { display:block; }
.news-item { display:flex; gap:12px; padding:12px 0; border-bottom:1px solid var(--border); }
.news-item:last-child { border-bottom:none; }
.news-dot { width:6px; height:6px; border-radius:50%; margin-top:6px; flex-shrink:0; }
.news-content { flex:1; }
.news-headline { font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:3px; line-height:1.4; }
.news-summary { font-size:12px; color:var(--text-secondary); line-height:1.5; margin-bottom:4px; }
.news-meta { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); }

/* ─── RISK MATRIX ─── */
.risk-table { width:100%; border-collapse:collapse; font-size:13px; }
.risk-table th { padding:10px 14px; background:var(--bg3); color:var(--text-secondary); font-weight:600; font-family:'IBM Plex Mono',monospace; font-size:11px; text-transform:uppercase; border-bottom:1px solid var(--border); text-align:left; }
.risk-table td { padding:10px 14px; border-bottom:1px solid var(--border); vertical-align:top; }
.risk-level { display:inline-flex; align-items:center; gap:4px; padding:2px 10px; border-radius:20px; font-size:11px; font-weight:600; font-family:'IBM Plex Mono',monospace; }
.risk-high { background:rgba(255,61,113,0.15); color:var(--accent-red); }
.risk-med { background:rgba(255,167,38,0.15); color:var(--accent-amber); }
.risk-low { background:rgba(0,230,118,0.15); color:var(--accent-green); }

/* ─── THEMES ─── */
.themes-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; }
@media(max-width:1100px){ .themes-grid { grid-template-columns:repeat(3,1fr); } }
@media(max-width:600px){ .themes-grid { grid-template-columns:repeat(2,1fr); } }
.theme-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:16px;
  transition:border-color 0.2s;
}
.theme-card:hover { border-color:var(--border2); }
.theme-card-icon { font-size:24px; margin-bottom:8px; }
.theme-card-title { font-size:13px; font-weight:700; color:var(--text-primary); margin-bottom:6px; }
.theme-card-body { font-size:11px; color:var(--text-secondary); line-height:1.6; }
.theme-card-tickers { display:flex; gap:4px; flex-wrap:wrap; margin-top:8px; }
.theme-ticker { font-family:'IBM Plex Mono',monospace; font-size:10px; padding:2px 7px; background:var(--bg3); border:1px solid var(--border2); border-radius:4px; color:var(--accent-cyan); }

/* ─── MASTER STRATEGY ─── */
.strategy-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
@media(max-width:900px){ .strategy-grid { grid-template-columns:1fr; } }
.strategy-card {
  background:var(--bg2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:18px;
}
.strategy-name { font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:4px; }
.strategy-quote { font-size:12px; color:var(--accent-amber); font-style:italic; margin-bottom:10px; border-left:2px solid var(--accent-amber); padding-left:8px; }
.strategy-points { list-style:none; display:flex; flex-direction:column; gap:6px; }
.strategy-points li { font-size:12px; color:var(--text-secondary); display:flex; gap:6px; }
.strategy-points li::before { content:'→'; color:var(--accent-blue); flex-shrink:0; }

/* ─── FOOTER ─── */
.footer {
  background:var(--bg2);
  border-top:1px solid var(--border);
  padding:20px 0;
  margin-top:32px;
}
.footer-content { display:flex; flex-wrap:wrap; gap:16px; align-items:flex-start; }
.footer-sources { font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--text-secondary); line-height:1.8; }
.footer-disclaimer { font-size:11px; color:var(--text-secondary); opacity:0.6; margin-top:8px; }

/* divider */
.divider { border:none; border-top:1px solid var(--border); margin:8px 0; }

/* scrollbar */
::-webkit-scrollbar { width:6px; height:6px; }
::-webkit-scrollbar-track { background:var(--bg); }
::-webkit-scrollbar-thumb { background:var(--border2); border-radius:3px; }
</style>
</head>
<body>

<!-- ══════════════════════ TICKER ══════════════════════ -->
<div class="ticker-wrap">
  <div class="ticker-inner" id="tickerInner">
    <!-- items duplicated for seamless loop -->
  </div>
</div>

<!-- ══════════════════════ HEADER ══════════════════════ -->
<div class="header">
  <div class="container">
    <div class="header-top">
      <div class="header-title">
        <div class="header-badges">
          <span class="badge badge-live">🔴 LIVE</span>
          <span class="badge badge-tw">🇹🇼 台股</span>
          <span class="badge badge-us">🇺🇸 美股</span>
          {% if tw_holiday_note %}
          <span class="badge badge-holiday">台股休市</span>
          {% endif %}
        </div>
        <div class="header-h1">📊 每日投資情報</div>
        <div class="header-sub">{{ date_label }}（{{ weekday_cn }}）· 台灣台中 · 資料截止：台股收盤 / 美股收盤</div>
      </div>
      <div class="header-pills">
        {% for pill in header_pills %}
        <div class="pill pill-{{ pill.tone }}"><span class="pill-icon">{{ pill.icon }}</span><span>{{ pill.text }}</span></div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════ HERO ══════════════════════ -->
<div class="section" style="background:var(--bg);">
  <div class="container">
    <div class="hero-grid">
      {% for hero in hero_events %}
      <div class="hero-card theme-{{ hero.theme }}">
        <div class="hero-label">{{ hero.flag }} {{ hero.label }}</div>
        <div class="hero-headline">{{ hero.headline }}</div>
        <div class="hero-body">{{ hero.body }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ══════════════════════ WARNINGS ══════════════════════ -->
<div class="section" style="background:var(--bg);">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">⚠️</span> 每日必看 5 大預警指標
      <span class="sec-subtitle">{{ date_label }}</span>
    </div>
    {% set status_badge = {'green': 'status-ok', 'amber': 'status-warn', 'red': 'status-danger'} %}
    <div class="warning-grid">
      <div class="w-card">
        <div class="w-card-label">VIX 恐懼指數</div>
        <div class="w-card-val {{ warning_indicators.vix.status }}">{{ "%.2f"|format(quotes.VIX.price) if quotes.VIX else "N/A" }}</div>
        <div class="w-card-sub">{{ warning_indicators.vix.note }}</div>
        <div class="w-card-status {{ status_badge.get(warning_indicators.vix.status, 'status-warn') }}">{{ warning_indicators.vix.status | upper }}</div>
      </div>
      <div class="w-card">
        <div class="w-card-label">HY 信用利差</div>
        <div class="w-card-val {{ warning_indicators.hy_spread.status }}">{{ warning_indicators.hy_spread.value_text }}</div>
        <div class="w-card-sub">{{ warning_indicators.hy_spread.note }}</div>
        <div class="w-card-status {{ status_badge.get(warning_indicators.hy_spread.status, 'status-warn') }}">{{ warning_indicators.hy_spread.status | upper }}</div>
      </div>
      <div class="w-card">
        <div class="w-card-label">10Y 美債殖利率</div>
        <div class="w-card-val {{ warning_indicators.us10y.status }}">{{ "%.2f"|format(quotes.US10Y.price) if quotes.US10Y else "N/A" }}%</div>
        <div class="w-card-sub">{{ warning_indicators.us10y.note }}</div>
        <div class="w-card-status {{ status_badge.get(warning_indicators.us10y.status, 'status-warn') }}">{{ warning_indicators.us10y.status | upper }}</div>
      </div>
      <div class="w-card">
        <div class="w-card-label">AI 龍頭線型</div>
        <div class="w-card-sub">{{ warning_indicators.ai_leaders.note }}</div>
        <div class="w-card-status {{ status_badge.get(warning_indicators.ai_leaders.status, 'status-warn') }}">{{ warning_indicators.ai_leaders.status | upper }}</div>
      </div>
      <div class="w-card">
        <div class="w-card-label">台股融資餘額</div>
        <div class="w-card-val {{ warning_indicators.tw_leverage.status }}">{{ warning_indicators.tw_leverage.value_text }}</div>
        <div class="w-card-sub">{{ warning_indicators.tw_leverage.note }}</div>
        <div class="w-card-status {{ status_badge.get(warning_indicators.tw_leverage.status, 'status-warn') }}">{{ warning_indicators.tw_leverage.status | upper }}</div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════ DATA VALIDATION ══════════════════════ -->
<div class="container" style="padding-bottom:8px">
  <div class="val-grid">
    {% for item in data_validation %}
    <div class="val-item"><span class="{{ 'val-ok' if item.status == 'confirmed' else 'val-est' }}">{{ '✓' if item.status == 'confirmed' else '⚠' }}</span>{{ item.label }}</div>
    {% endfor %}
  </div>
</div>

<!-- ══════════════════════ KPI ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">📌</span> 核心 KPI 看板
      <span class="sec-subtitle">主要指標快覽</span>
    </div>
    <div class="kpi-grid">
      {% for kpi in kpi_cards[:4] %}
      <div class="kpi-card">
        <div class="kpi-label">{{ kpi.label }}</div>
        <div class="kpi-val {{ kpi.val_class }}">{{ kpi.val }}</div>
        <div class="kpi-sub"><span class="kpi-change {{ kpi.change_class }}">{{ kpi.change_text }}</span>{% if kpi.extra %} · {{ kpi.extra }}{% endif %}</div>
      </div>
      {% endfor %}
    </div>
    <div class="kpi-grid" style="margin-top:12px">
      {% for kpi in kpi_cards[4:8] %}
      <div class="kpi-card">
        <div class="kpi-label">{{ kpi.label }}</div>
        <div class="kpi-val {{ kpi.val_class }}">{{ kpi.val }}</div>
        <div class="kpi-sub"><span class="kpi-change {{ kpi.change_class }}">{{ kpi.change_text }}</span>{% if kpi.extra %} · {{ kpi.extra }}{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ══════════════════════ AI INFRA VERIFICATION ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🏗️</span> AI 基礎建設驗證指標
      <span class="sec-subtitle">CSP Capex · AI 伺服器出貨 · HBM 價差</span>
    </div>
    {{ ai_infra_html | safe }}
  </div>
</div>

<!-- ══════════════════════ VIX CHART ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">😱</span> 美股 VIX 恐懼指數 — 近 6 個月趨勢
      <span class="sec-subtitle">{{ vix_history[0].date if vix_history else "—" }} ～ {{ vix_history[-1].date if vix_history else "—" }}</span>
    </div>
    <div class="chart-card">
      <div class="chart-title">CBOE VIX 恐懼指數</div>
      <div class="chart-sub">日線資料 · 警戒線 VIX 20（橘）/ 恐慌線 VIX 30（紅）</div>
      <div class="vix-legend">
        <div class="vix-leg-item"><div class="vix-leg-dot" style="background:var(--accent-green)"></div>VIX &lt; 15（貪婪）</div>
        <div class="vix-leg-item"><div class="vix-leg-dot" style="background:var(--accent-amber)"></div>VIX 15–25（警戒）</div>
        <div class="vix-leg-item"><div class="vix-leg-dot" style="background:var(--accent-red)"></div>VIX &gt; 25（恐慌）</div>
        <div class="vix-leg-item"><div class="vix-leg-dot" style="background:rgba(255,167,38,0.6);height:1px;width:20px"></div>VIX 20 警戒線</div>
        <div class="vix-leg-item"><div class="vix-leg-dot" style="background:rgba(255,61,113,0.6);height:1px;width:20px"></div>VIX 30 恐慌線</div>
      </div>
      <canvas id="vixChart" height="90"></canvas>
    </div>
  </div>
</div>

<!-- ══════════════════════ P/E CHART ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">📐</span> 本益比（P/E）趨勢圖
      <span class="sec-subtitle">實線 Trailing TTM · 虛線 Forward</span>
    </div>
    <div class="chart-card" style="position:relative">
      <div class="chart-title">本益比（P/E）趨勢 — 實線 Trailing TTM / 虛線 Forward</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
        <div class="tab-bar" style="margin:0">
          <button class="tab-btn active" onclick="switchPEMarket('tw',this)">🇹🇼 台股</button>
          <button class="tab-btn" onclick="switchPEMarket('us',this)">🇺🇸 美股</button>
        </div>
        <div class="tab-bar" style="margin:0">
          <button class="tab-btn active" onclick="switchPEPeriod('1y',this)" id="pe-1y-btn">1Y</button>
          <button class="tab-btn" onclick="switchPEPeriod('3y',this)" id="pe-3y-btn">3Y</button>
        </div>
      </div>
      <div id="pe-overlay-tw" class="pe-overlay">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text-secondary);margin-bottom:6px">當前 P/E 對比</div>
        {% for item in pe_data.tw %}
        <div class="pe-ov-row"><span class="pe-ov-name" style="color:{{ item.color }}">{{ item.name }}</span><span>Trailing: {{ item.current_trailing_pe if item.current_trailing_pe is not none else "N/A" }}</span><span>Fwd: {{ item.current_forward_pe if item.current_forward_pe is not none else "N/A" }}</span></div>
        {% endfor %}
      </div>
      <div id="pe-overlay-us" class="pe-overlay" style="display:none">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text-secondary);margin-bottom:6px">當前 P/E 對比</div>
        {% for item in pe_data.us %}
        <div class="pe-ov-row"><span class="pe-ov-name" style="color:{{ item.color }}">{{ item.name }}</span><span>Trailing: {{ item.current_trailing_pe if item.current_trailing_pe is not none else "N/A" }}</span><span>Fwd: {{ item.current_forward_pe if item.current_forward_pe is not none else "N/A" }}</span></div>
        {% endfor %}
      </div>
      <div style="position:relative;height:340px">
        <canvas id="peChart"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════ KOREA MARKET ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🇰🇷</span> 韓國股市
      <span class="sec-subtitle">{{ date_label }}</span>
    </div>
    <div class="kpi-grid">
      {% for key in ["KOSPI", "SAMSUNG", "SK_HYNIX"] %}
      {% if korea.get(key) %}
      {% set item = korea[key] %}
      <div class="kpi-card">
        <div class="kpi-label">{{ item.name }}</div>
        <div class="kpi-val {{ 'green' if item.change >= 0 else 'red' }}">{{ '{:,g}'.format(item.price) }}</div>
        <div class="kpi-sub"><span class="kpi-change {{ 'green' if item.change >= 0 else 'red' }}">{{ '{:+,g}'.format(item.change) }} ({{ '{:+.2f}'.format(item.change_pct) }}%)</span></div>
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- ══════════════════════ US HEATMAP ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🗺️</span> 美股熱力圖
      <span class="sec-subtitle">{{ date_label }} 當日漲跌</span>
    </div>
    <div class="heatmap-grid">
      {% for item in heatmap %}
      <div class="heatmap-cell {{ item.color_class }}">
        <div class="heatmap-symbol">{{ item.symbol }}</div>
        <div class="heatmap-pct">{{ '{:+.2f}'.format(item.change_pct) }}%</div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<!-- ══════════════════════ SECTOR ROTATION ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🔄</span> 美股資金板塊輪動
      <span class="sec-subtitle">11 檔 SPDR 產業 ETF · 依當日表現排序</span>
    </div>
    <div class="chart-card">
      <table class="risk-table">
        <thead><tr><th>產業</th><th>代號</th><th>當日</th><th>一週</th></tr></thead>
        <tbody>
          {% for item in sector_rotation %}
          <tr>
            <td>{{ item.name }}</td>
            <td>{{ item.symbol }}</td>
            <td class="{{ 'green' if item.change_pct_1d >= 0 else 'red' }}">{{ '{:+.2f}'.format(item.change_pct_1d) }}%</td>
            <td class="{{ 'green' if item.change_pct_1w >= 0 else 'red' }}">{{ '{:+.2f}'.format(item.change_pct_1w) }}%</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════════ OIL CHART ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🛢️</span> 油價走勢 — 近 6 個月
      <span class="sec-subtitle">{{ oil.dates[0] if oil.dates else "—" }} ～ {{ oil.dates[-1] if oil.dates else "—" }}</span>
    </div>
    <div class="chart-card">
      <div class="chart-title">WTI / Brent 原油價格（美元/桶）</div>
      <canvas id="oilChart" height="90"></canvas>
    </div>
  </div>
</div>

<!-- ══════════════════════ FUTURES ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🌙</span> 台指期夜盤動態
      <span class="sec-subtitle">夜盤時段 15:00–05:00（台灣時間）</span>
    </div>
    {% set night_up = night_session.change_pts is string and not night_session.change_pts.strip().startswith('-') %}
    <div class="futures-card">
      <div class="futures-main">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text-secondary);margin-bottom:4px">台指期 夜盤最新報價</div>
          <div class="futures-price {{ 'green' if night_up else 'red' }}">{{ night_session.price }}</div>
          <div style="display:flex;gap:10px;align-items:center;margin-top:4px">
            <div class="futures-chg {{ 'green' if night_up else 'red' }}">{{ night_session.change_pts }}</div>
            <div class="futures-chg {{ 'green' if night_up else 'red' }}">({{ night_session.change_pct }})</div>
          </div>
        </div>
        <div style="padding:10px;background:rgba(255,255,255,0.04);border:1px solid var(--border2);border-radius:8px;font-size:12px;color:var(--text-secondary)">
          {{ night_session.vs_day_close_note }}
        </div>
      </div>
      <div class="futures-meta-grid">
        <div class="futures-meta-item">
          <div class="futures-meta-label">夜盤最新</div>
          <div class="futures-meta-val {{ 'green' if night_up else 'red' }}">{{ night_session.price }}</div>
        </div>
        <div class="futures-meta-item">
          <div class="futures-meta-label">漲跌點數</div>
          <div class="futures-meta-val {{ 'green' if night_up else 'red' }}">{{ night_session.change_pts }} ({{ night_session.change_pct }})</div>
        </div>
        <div class="futures-meta-item">
          <div class="futures-meta-label">成交量</div>
          <div class="futures-meta-val" style="font-size:14px">{{ night_session.volume }}</div>
        </div>
        <div class="futures-meta-item">
          <div class="futures-meta-label">夜盤時段</div>
          <div class="futures-meta-val" style="font-size:13px">15:00–05:00</div>
        </div>
      </div>
      <div style="margin-top:12px;padding:10px;background:rgba(255,167,38,0.06);border:1px solid rgba(255,167,38,0.2);border-radius:8px;font-size:12px;color:var(--text-secondary)">
        {{ night_session.source_note }}
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════ INSTITUTION TABLE ══════════════════════ -->
<div class="section">
  <div class="container">
    <div class="sec-title">
      <span class="sec-title-icon">🏦</span> 法人連三日同向買賣超排行
    </div>
    <div class="header-sub">資料截止：{{ institutional.as_of_dates[-1] if institutional.as_of_dates else "—" }}（TWSE OpenAPI，估算金額）</div>
    <!-- Summary -->
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px">
      {% for item in institutional_summary %}
      <div style="background:var(--bg3);border:1px solid {{ 'var(--border2)' if item.emphasize else 'var(--border)' }};border-radius:8px;padding:10px 18px;font-family:'IBM Plex Mono',monospace;font-size:12px">
        <span style="color:var(--text-secondary)">{{ item.label }}　</span><span class="{{ item.tone }}"{% if item.emphasize %} style="font-weight:700"{% endif %}>{{ item.text }}</span>
      </div>
      {% endfor %}
    </div>

    <div class="inst-tabs">
      <button class="tab-btn active" onclick="switchInst('foreign',this)">🌐 外資</button>
      <button class="tab-btn" onclick="switchInst('trust',this)">📦 投信</button>
    </div>

    <!-- 外資 -->
    <div id="inst-foreign" class="inst-panel active">
      <div class="inst-cols">
        <div class="inst-col">
          <div class="inst-col-header buy">▲ 連三日買超前十（外資）</div>
          <table class="inst-table">
            <thead><tr><th>#</th><th>股號</th><th>股名</th><th>三日買超(億)</th><th>三日張數</th></tr></thead>
            <tbody>
              {% for row in institutional.foreign_buy_top10 %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ row.code }}</td>
                <td>{{ row.name }}</td>
                <td class="inst-amt-buy">{{ row.amount_display }}</td>
                <td class="inst-amt-buy">{{ row.lots_display }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="inst-col">
          <div class="inst-col-header sell">▼ 連三日賣超前十（外資）</div>
          <table class="inst-table">
            <thead><tr><th>#</th><th>股號</th><th>股名</th><th>三日賣超(億)</th><th>三日張數</th></tr></thead>
            <tbody>
              {% for row in institutional.foreign_sell_top10 %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ row.code }}</td>
                <td>{{ row.name }}</td>
                <td class="inst-amt-sell">{{ row.amount_display }}</td>
                <td class="inst-amt-sell">{{ row.lots_display }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- 投信 -->
    <div id="inst-trust" class="inst-panel">
      <div class="inst-cols">
        <div class="inst-col">
          <div class="inst-col-header buy">▲ 連三日買超前十（投信）</div>
          <table class="inst-table">
            <thead><tr><th>#</th><th>股號</th><th>股名</th><th>三日買超(億)</th><th>三日張數</th></tr></thead>
            <tbody>
              {% for row in institutional.trust_buy_top10 %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ row.code }}</td>
                <td>{{ row.name }}</td>
                <td class="inst-amt-buy">{{ row.amount_display }}</td>
                <td class="inst-amt-buy">{{ row.lots_display }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="inst-col">
          <div class="inst-col-header sell">▼ 連三日賣超前十（投信）</div>
          <table class="inst-table">
            <thead><tr><th>#</th><th>股號</th><th>股名</th><th>三日賣超(億)</th><th>三日張數</th></tr></thead>
            <tbody>
              {% for row in institutional.trust_sell_top10 %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ row.code }}</td>
                <td>{{ row.name }}</td>
